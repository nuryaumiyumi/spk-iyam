/* ─── TABLE HELPERS ─────────────────────────────────────── */
function TableHead({ cols }) {
  return (
    <thead>
      <tr style={{ background:C.tableHead }}>
        {cols.map(h => <th key={h} style={TH}>{h}</th>)}
      </tr>
    </thead>
  );
}
function PaginationRow({ page, perPage, total, totalItems, onChange }) {
  const start = (page - 1) * perPage + 1;
  const end = Math.min(page * perPage, totalItems);
  return (
    <div style={{ padding:"10px 18px", borderTop:"1px solid "+C.border, display:"flex", alignItems:"center", justifyContent:"space-between" }}>
      <span style={{ fontSize:12, color:"#9ca3af" }}>Menampilkan {start} sampai {end} dari {totalItems} data</span>
      <Pagination current={page} total={total} onChange={onChange} />
    </div>
  );
}

/* ─── DASHBOARD VIEW ────────────────────────────────────── */
function DashboardView({ tomats, kriterias, go }) {
  const [page, setPage] = useState(1);
  const PER = 10;
  const totalPages = Math.ceil(tomats.length / PER);
  const data = tomats.slice((page - 1) * PER, page * PER);
  const ranking = useMemo(() => saw(tomats, kriterias), [tomats, kriterias]);
  const best = ranking[0];

  return (
    <div style={{ display:"flex", flexDirection:"column", gap:20 }}>
      {/* Hero */}
      <div style={{ background:"linear-gradient(135deg,#fff5f5 0%,#fff 78%)", border:"1px solid #fecaca", borderRadius:12, padding:"28px 32px", display:"flex", alignItems:"center", justifyContent:"space-between", overflow:"hidden", position:"relative" }}>
        <div style={{ position:"absolute", right:320, top:-55, width:190, height:190, borderRadius:"50%", background:"rgba(252,165,165,0.12)" }}/>
        <div style={{ position:"absolute", right:245, bottom:-75, width:230, height:230, borderRadius:"50%", background:"rgba(252,165,165,0.08)" }}/>
        <div style={{ zIndex:1 }}>
          <div style={{ fontSize:21, fontWeight:700, color:C.text, marginBottom:4 }}>Sistem Pendukung Keputusan</div>
          <div style={{ fontSize:25, fontWeight:700, color:C.darkRed, marginBottom:14 }}>Pemilihan Tomat Berkualitas Tinggi</div>
          <p style={{ color:C.textLt, fontSize:13.5, maxWidth:370, lineHeight:1.65, margin:"0 0 20px" }}>
            Kelola data tomat, kriteria, penilaian,<br/>dan lakukan perankingan menggunakan metode SAW.
          </p>
          <button onClick={() => go("perhitunganSaw")} style={{ background:C.darkRed, color:"white", border:"none", borderRadius:8, padding:"10px 20px", cursor:"pointer", fontSize:13.5, fontWeight:600, display:"flex", alignItems:"center", gap:8 }}>
            <Database size={15} />Mulai Hitung SAW
          </button>
        </div>
        <div style={{ width:285, height:188, zIndex:1, flexShrink:0 }}><TomatoHero /></div>
      </div>

      {/* Stats */}
      <div style={{ display:"grid", gridTemplateColumns:"repeat(4,1fr)", gap:14 }}>
        <StatCard icon={<Apple size={22}/>}       iconBg="#fee2e2" iconColor={C.red}     value={tomats.length}  label="Total Data Tomat" sub="Data alternatif"/>
        <StatCard icon={<BarChart3 size={22}/>}   iconBg="#fef9c3" iconColor="#f59e0b"   value={kriterias.length} label="Total Kriteria"   sub="Kriteria penilaian"/>
        <StatCard icon={<ClipboardList size={22}/>} iconBg="#dcfce7" iconColor="#22c55e" value={tomats.length}  label="Total Penilaian"  sub="Data penilaian"/>
        <StatCard icon={<Star size={22}/>}        iconBg="#f3e8ff" iconColor="#8b5cf6"
          value={best?.tomat.kode || "-"} label="Tomat Terbaik"
          sub={best ? `${best.tomat.nama} (${best.nilai.toFixed(4)})` : "-"}/>
      </div>

      {/* Table + Info */}
      <div style={{ display:"grid", gridTemplateColumns:"1fr 308px", gap:16, alignItems:"start" }}>
        {/* Table */}
        <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, overflow:"hidden" }}>
          <div style={{ padding:"14px 18px", borderBottom:"1px solid "+C.border, display:"flex", alignItems:"center", justifyContent:"space-between" }}>
            <span style={{ fontWeight:600, color:C.text, fontSize:14.5 }}>Data Tomat Terbaru</span>
            <button onClick={() => go("dataTomat")} style={{ background:"none", border:"none", color:"#3b82f6", fontSize:12.5, cursor:"pointer", display:"flex", alignItems:"center", gap:3 }}>
              Lihat Semua <ChevronRight size={13}/>
            </button>
          </div>
          <div style={{ overflowX:"auto" }}>
            <table style={{ width:"100%", borderCollapse:"collapse" }}>
              <TableHead cols={["No","Kode","Nama Tomat","Berat (g)","Warna (1-5)","Kesegaran (1-10)","Cacat (%)","Aksi"]}/>
              <tbody>
                {data.map((t, i) => (
                  <tr key={t.id} style={{ borderTop:"1px solid #f3f4f6" }}>
                    <td style={TD}>{(page-1)*PER+i+1}</td>
                    <td style={{ ...TD, fontWeight:500 }}>{t.kode}</td>
                    <td style={TD}>{t.nama}</td>
                    <td style={{ ...TD, textAlign:"center" }}>{t.berat}</td>
                    <td style={{ ...TD, textAlign:"center" }}>{t.warna}</td>
                    <td style={{ ...TD, textAlign:"center" }}>{t.kesegaran}</td>
                    <td style={{ ...TD, textAlign:"center" }}>{t.cacat}</td>
                    <td style={{ padding:"8px 14px" }}>
                      <div style={{ display:"flex", gap:5 }}>
                        <button style={{ ...BTN, color:"#6b7280", background:"#f9fafb" }}><Eye size={13}/></button>
                        <button style={{ ...BTN, color:"#f59e0b", background:"#fef9c3" }}><Pencil size={13}/></button>
                        <button style={{ ...BTN, color:C.red,    background:"#fee2e2" }}><Trash2 size={13}/></button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <PaginationRow page={page} perPage={PER} total={totalPages} totalItems={tomats.length} onChange={setPage}/>
        </div>

        {/* Info Panel */}
        <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, overflow:"hidden" }}>
          <div style={{ padding:"14px 18px", borderBottom:"1px solid "+C.border }}>
            <span style={{ fontWeight:600, color:C.text, fontSize:14.5 }}>Informasi Sistem</span>
          </div>
          <div style={{ padding:"16px 18px" }}>
            <div style={{ display:"flex", gap:12 }}>
              <div style={{ width:33, height:33, borderRadius:"50%", background:"#dbeafe", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0 }}>
                <Info size={15} style={{ color:"#3b82f6" }} />
              </div>
              <p style={{ fontSize:12.5, color:"#4b5563", lineHeight:1.75, margin:0 }}>
                Sistem Pendukung Keputusan Pemilihan Tomat Berkualitas Tinggi menggunakan metode SAW (Simple Additive Weighting). Sistem membantu pengguna menentukan tomat terbaik berdasarkan kriteria yang telah ditetapkan secara objektif dan cepat.
              </p>
            </div>
            <TomatoInfo />
          </div>
        </div>
      </div>
    </div>
  );
}

/* ─── DATA TOMAT VIEW ───────────────────────────────────── */
function DataTomatView({ tomats, setTomats }) {
  const [page, setPage] = useState(1);
  const [modal, setModal] = useState(null);
  const [form, setForm] = useState({ kode:"", nama:"", berat:180, warna:3, kesegaran:7, cacat:2 });
  const PER = 10;
  const totalPages = Math.ceil(tomats.length / PER);
  const data = tomats.slice((page - 1) * PER, page * PER);

  const openAdd = () => {
    const n = tomats.length + 1;
    setForm({ kode:`T${String(n).padStart(3,"0")}`, nama:`Tomat ${n}`, berat:180, warna:3, kesegaran:7, cacat:2 });
    setModal({ mode:"add" });
  };
  const openEdit = t => {
    setForm({ kode:t.kode, nama:t.nama, berat:t.berat, warna:t.warna, kesegaran:t.kesegaran, cacat:t.cacat });
    setModal({ mode:"edit", id:t.id });
  };
  const del = id => { if (confirm("Hapus data tomat ini?")) setTomats(tomats.filter(t => t.id !== id)); };
  const save = () => {
    if (modal.mode === "add") {
      const id = Math.max(...tomats.map(t => t.id), 0) + 1;
      setTomats([...tomats, { id, ...form }]);
    } else {
      setTomats(tomats.map(t => t.id === modal.id ? { ...t, ...form } : t));
    }
    setModal(null);
  };

  const inp = (key, label, type="text", min, max) => (
    <div key={key}>
      <label style={{ fontSize:12, fontWeight:600, color:C.textMd, display:"block", marginBottom:4 }}>{label}</label>
      <input type={type} value={form[key]} min={min} max={max}
        onChange={e => setForm({ ...form, [key]: type === "number" ? +e.target.value : e.target.value })}
        style={{ width:"100%", padding:"8px 11px", border:"1px solid "+C.border, borderRadius:7, fontSize:13, boxSizing:"border-box", outline:"none", color:C.text }}
      />
    </div>
  );

  return (
    <div>
      <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, overflow:"hidden" }}>
        <div style={{ padding:"14px 18px", borderBottom:"1px solid "+C.border, display:"flex", alignItems:"center", justifyContent:"space-between" }}>
          <span style={{ fontWeight:600, color:C.text, fontSize:15 }}>Data Tomat (Alternatif)</span>
          <button onClick={openAdd} style={{ background:C.darkRed, color:"white", border:"none", borderRadius:7, padding:"8px 15px", cursor:"pointer", fontSize:13, fontWeight:600, display:"flex", alignItems:"center", gap:5 }}>
            <Plus size={14}/>Tambah Tomat
          </button>
        </div>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%", borderCollapse:"collapse" }}>
            <TableHead cols={["No","Kode","Nama Tomat","Berat (g)","Warna (1-5)","Kesegaran (1-10)","Cacat (%)","Aksi"]}/>
            <tbody>
              {data.map((t, i) => (
                <tr key={t.id} style={{ borderTop:"1px solid #f3f4f6" }}>
                  <td style={TD}>{(page-1)*PER+i+1}</td>
                  <td style={{ ...TD, fontWeight:500 }}>{t.kode}</td>
                  <td style={TD}>{t.nama}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{t.berat}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{t.warna}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{t.kesegaran}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{t.cacat}</td>
                  <td style={{ padding:"8px 14px" }}>
                    <div style={{ display:"flex", gap:5 }}>
                      <button onClick={() => openEdit(t)} style={{ ...BTN, color:"#6b7280", background:"#f9fafb" }}><Eye size={13}/></button>
                      <button onClick={() => openEdit(t)} style={{ ...BTN, color:"#f59e0b", background:"#fef9c3" }}><Pencil size={13}/></button>
                      <button onClick={() => del(t.id)}   style={{ ...BTN, color:C.red,    background:"#fee2e2" }}><Trash2 size={13}/></button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <PaginationRow page={page} perPage={PER} total={totalPages} totalItems={tomats.length} onChange={setPage}/>
      </div>
      {modal && (
        <Modal title={modal.mode === "add" ? "Tambah Data Tomat" : "Edit Data Tomat"} onClose={() => setModal(null)}>
          <div style={{ display:"flex", flexDirection:"column", gap:12 }}>
            {inp("kode","Kode")}
            {inp("nama","Nama Tomat")}
            {inp("berat","Berat (g)","number",50,500)}
            {inp("warna","Warna (1-5)","number",1,5)}
            {inp("kesegaran","Kesegaran (1-10)","number",1,10)}
            {inp("cacat","Cacat (%)","number",0,100)}
            <button onClick={save} style={{ background:C.darkRed, color:"white", border:"none", borderRadius:7, padding:10, cursor:"pointer", fontSize:13.5, fontWeight:600, marginTop:4 }}>Simpan</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

/* ─── KRITERIA VIEW ─────────────────────────────────────── */
function KriteriaView({ kriterias, setKriterias }) {
  const total = kriterias.reduce((s, k) => s + k.bobot, 0);
  const ok = Math.abs(total - 1) < 0.001;
  return (
    <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, padding:24 }}>
      <h2 style={{ margin:"0 0 20px", fontSize:15, fontWeight:700, color:C.text }}>Kriteria & Bobot Penilaian</h2>
      <div style={{ display:"flex", flexDirection:"column", gap:16 }}>
        {kriterias.map(k => (
          <div key={k.id} style={{ background:"#f9fafb", borderRadius:10, padding:16, border:"1px solid "+C.border }}>
            <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:10 }}>
              <div>
                <span style={{ fontWeight:600, color:C.text, fontSize:14 }}>{k.nama}</span>
                <span style={{ marginLeft:8, fontSize:10.5, fontWeight:700, padding:"2px 7px", borderRadius:20,
                  background:k.tipe==="benefit"?"#dcfce7":"#fee2e2",
                  color:k.tipe==="benefit"?"#16a34a":"#dc2626", textTransform:"uppercase" }}>{k.tipe}</span>
              </div>
              <span style={{ fontSize:19, fontWeight:700, color:C.darkRed, background:"#fee2e2", padding:"3px 12px", borderRadius:7 }}>
                {(k.bobot * 100).toFixed(0)}%
              </span>
            </div>
            <input type="range" min={0} max={1} step={0.01} value={k.bobot}
              onChange={e => setKriterias(kriterias.map(x => x.id === k.id ? { ...x, bobot: parseFloat(e.target.value) } : x))}
              style={{ width:"100%", accentColor:C.darkRed, cursor:"pointer" }}/>
          </div>
        ))}
      </div>
      <div style={{ marginTop:16, padding:"11px 16px", borderRadius:8, border:"1px solid "+(ok?"#bbf7d0":"#fecaca"), background:ok?"#f0fdf4":"#fef2f2", display:"flex", justifyContent:"space-between" }}>
        <span style={{ fontSize:13, color:ok?"#166534":"#dc2626", fontWeight:500 }}>Total Bobot</span>
        <span style={{ fontSize:15, fontWeight:700, color:ok?"#16a34a":"#dc2626" }}>{total.toFixed(2)} {ok?"✓":"⚠️"}</span>
      </div>
    </div>
  );
}

/* ─── PENILAIAN VIEW ────────────────────────────────────── */
function PenilaianView({ tomats, kriterias, setTomats }) {
  const [page, setPage] = useState(1);
  const PER = 10;
  const totalPages = Math.ceil(tomats.length / PER);
  const data = tomats.slice((page - 1) * PER, page * PER);
  const upd = (id, f, v) => setTomats(tomats.map(t => t.id === id ? { ...t, [f]: v } : t));
  return (
    <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, overflow:"hidden" }}>
      <div style={{ padding:"14px 18px", borderBottom:"1px solid "+C.border }}>
        <h2 style={{ margin:0, fontSize:15, fontWeight:700, color:C.text }}>Matriks Penilaian</h2>
        <p style={{ margin:"3px 0 0", fontSize:12, color:"#9ca3af" }}>Edit nilai kriteria langsung pada tabel</p>
      </div>
      <div style={{ overflowX:"auto" }}>
        <table style={{ width:"100%", borderCollapse:"collapse" }}>
          <thead>
            <tr style={{ background:C.tableHead }}>
              <th style={TH}>No</th><th style={TH}>Kode</th><th style={TH}>Nama</th>
              {kriterias.map(k => <th key={k.id} style={TH}>{k.nama}</th>)}
            </tr>
          </thead>
          <tbody>
            {data.map((t, i) => (
              <tr key={t.id} style={{ borderTop:"1px solid #f3f4f6" }}>
                <td style={TD}>{(page-1)*PER+i+1}</td>
                <td style={{ ...TD, fontWeight:500 }}>{t.kode}</td>
                <td style={TD}>{t.nama}</td>
                {kriterias.map(k => (
                  <td key={k.id} style={{ padding:"7px 10px" }}>
                    <input type="number" value={t[k.id]}
                      onChange={e => upd(t.id, k.id, +e.target.value)}
                      style={{ width:60, padding:"5px 7px", border:"1px solid "+C.border, borderRadius:6, fontSize:12.5, textAlign:"center", outline:"none" }}/>
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <PaginationRow page={page} perPage={PER} total={totalPages} totalItems={tomats.length} onChange={setPage}/>
    </div>
  );
}

/* ─── PERHITUNGAN SAW VIEW ──────────────────────────────── */
function PerhitunganSAWView({ tomats, kriterias }) {
  const ranking = useMemo(() => saw(tomats, kriterias), [tomats, kriterias]);
  return (
    <div style={{ display:"flex", flexDirection:"column", gap:18 }}>
      {/* Bobot */}
      <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, padding:22 }}>
        <h2 style={{ margin:"0 0 14px", fontSize:15, fontWeight:700, color:C.text }}>1. Bobot & Tipe Kriteria</h2>
        <div style={{ display:"grid", gridTemplateColumns:"repeat(4,1fr)", gap:10 }}>
          {kriterias.map(k => (
            <div key={k.id} style={{ background:"#f9fafb", borderRadius:9, padding:"13px 14px", border:"1px solid "+C.border, textAlign:"center" }}>
              <div style={{ fontSize:11, color:"#9ca3af", marginBottom:3 }}>{k.nama}</div>
              <div style={{ fontSize:22, fontWeight:700, color:C.darkRed }}>{(k.bobot*100).toFixed(0)}%</div>
              <div style={{ fontSize:9.5, fontWeight:700, padding:"2px 7px", borderRadius:20, display:"inline-block", marginTop:4,
                background:k.tipe==="benefit"?"#dcfce7":"#fee2e2",
                color:k.tipe==="benefit"?"#16a34a":"#dc2626", textTransform:"uppercase" }}>{k.tipe}</div>
            </div>
          ))}
        </div>
      </div>
      {/* Normalisasi */}
      <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, padding:22 }}>
        <h2 style={{ margin:"0 0 4px", fontSize:15, fontWeight:700, color:C.text }}>2. Matriks Normalisasi (R)</h2>
        <p style={{ fontSize:11.5, color:"#9ca3af", margin:"0 0 14px" }}>Benefit: Xij / max(Xj) &nbsp;|&nbsp; Cost: min(Xj) / Xij</p>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%", borderCollapse:"collapse" }}>
            <thead><tr style={{ background:C.tableHead }}>
              <th style={TH}>Alternatif</th>
              {kriterias.map(k => <th key={k.id} style={TH}>{k.nama}</th>)}
            </tr></thead>
            <tbody>
              {ranking.slice(0, 10).map(({ tomat, nr }) => (
                <tr key={tomat.id} style={{ borderTop:"1px solid #f3f4f6" }}>
                  <td style={{ ...TD, fontWeight:500 }}>{tomat.nama}</td>
                  {nr.map((v, i) => (
                    <td key={i} style={{ ...TD, textAlign:"center", color:v>=0.95?"#16a34a":v<=0.55?"#ef4444":TD.color, fontWeight:v===1?700:400 }}>
                      {v.toFixed(4)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          {ranking.length > 10 && <p style={{ fontSize:11, color:"#9ca3af", padding:"6px 14px", margin:0 }}>... menampilkan 10 dari {ranking.length} data</p>}
        </div>
      </div>
      {/* Preferensi */}
      <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, padding:22 }}>
        <h2 style={{ margin:"0 0 14px", fontSize:15, fontWeight:700, color:C.text }}>3. Nilai Preferensi (V) = Σ(Rij × Wj)</h2>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%", borderCollapse:"collapse" }}>
            <thead><tr style={{ background:C.tableHead }}>
              <th style={TH}>Rank</th><th style={TH}>Kode</th><th style={TH}>Nama Tomat</th><th style={TH}>Nilai Preferensi</th>
            </tr></thead>
            <tbody>
              {ranking.map(({ tomat, nilai }, i) => (
                <tr key={tomat.id} style={{ borderTop:"1px solid #f3f4f6", background:i===0?"#fff7ed":"transparent" }}>
                  <td style={{ ...TD, fontWeight:700, color:i<3?"#f59e0b":C.textMd }}>
                    {i===0?"🥇":i===1?"🥈":i===2?"🥉":i+1}
                  </td>
                  <td style={{ ...TD, fontWeight:500 }}>{tomat.kode}</td>
                  <td style={TD}>{tomat.nama}</td>
                  <td style={{ ...TD, textAlign:"center", fontWeight:700, color:C.darkRed }}>{nilai.toFixed(4)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

/* ─── HASIL RANKING VIEW ────────────────────────────────── */
function HasilRankingView({ tomats, kriterias }) {
  const ranking = useMemo(() => saw(tomats, kriterias), [tomats, kriterias]);
  const best = ranking[0];
  return (
    <div style={{ display:"flex", flexDirection:"column", gap:18 }}>
      {best && (
        <div style={{ background:"linear-gradient(135deg,#fff7ed,#fef2f2)", border:"1px solid #fecaca", borderRadius:12, padding:22, display:"flex", alignItems:"center", gap:20 }}>
          <div style={{ width:72, height:72, borderRadius:"50%", background:"linear-gradient(135deg,#fbbf24,#f59e0b)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:34, flexShrink:0 }}>🏆</div>
          <div>
            <div style={{ fontSize:10.5, fontWeight:700, color:"#9ca3af", letterSpacing:"0.12em", textTransform:"uppercase", marginBottom:4 }}>Tomat Terbaik SAW</div>
            <div style={{ fontSize:22, fontWeight:700, color:C.text, marginBottom:3 }}>{best.tomat.nama}</div>
            <div style={{ fontSize:13, color:C.textLt }}>Kode: <strong>{best.tomat.kode}</strong> &nbsp;|&nbsp; Nilai SAW: <strong style={{ color:C.darkRed }}>{best.nilai.toFixed(4)}</strong></div>
          </div>
        </div>
      )}
      <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, overflow:"hidden" }}>
        <div style={{ padding:"14px 18px", borderBottom:"1px solid "+C.border }}>
          <h2 style={{ margin:0, fontSize:15, fontWeight:700, color:C.text }}>Hasil Ranking SAW</h2>
        </div>
        <div style={{ overflowX:"auto" }}>
          <table style={{ width:"100%", borderCollapse:"collapse" }}>
            <thead><tr style={{ background:C.tableHead }}>
              {["Rank","Kode","Nama Tomat","Berat","Warna","Kesegaran","Cacat","Nilai SAW"].map(h=><th key={h} style={TH}>{h}</th>)}
            </tr></thead>
            <tbody>
              {ranking.map(({ tomat, nilai }, i) => (
                <tr key={tomat.id} style={{ borderTop:"1px solid #f3f4f6", background:i<3?"#fffbeb":"transparent" }}>
                  <td style={{ ...TD, fontWeight:700 }}>
                    <span style={{ display:"inline-flex", alignItems:"center", justifyContent:"center", width:22, height:22, borderRadius:"50%", fontSize:10, fontWeight:700,
                      background:i===0?"#fbbf24":i===1?"#9ca3af":i===2?"#cd7c2f":"#f3f4f6",
                      color:i<3?"white":"#6b7280" }}>{i+1}</span>
                  </td>
                  <td style={{ ...TD, fontWeight:500 }}>{tomat.kode}</td>
                  <td style={TD}>{tomat.nama}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{tomat.berat}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{tomat.warna}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{tomat.kesegaran}</td>
                  <td style={{ ...TD, textAlign:"center" }}>{tomat.cacat}</td>
                  <td style={{ ...TD, textAlign:"center", fontWeight:700, color:C.darkRed }}>{nilai.toFixed(4)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

/* ─── IMPORT JSON VIEW ──────────────────────────────────── */
function ImportJsonView({ setTomats }) {
  const [status, setStatus] = useState(null);
  return (
    <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, padding:24 }}>
      <h2 style={{ margin:"0 0 8px", fontSize:15, fontWeight:700, color:C.text }}>Import Data JSON</h2>
      <p style={{ fontSize:13, color:C.textLt, margin:"0 0 20px" }}>Upload file JSON berisi array data tomat untuk mengimpor data baru.</p>
      <div style={{ border:"2px dashed "+C.border, borderRadius:10, padding:"36px 24px", textAlign:"center", marginBottom:16 }}>
        <Download size={34} style={{ color:"#9ca3af", margin:"0 auto 12px", display:"block" }}/>
        <p style={{ color:C.textLt, fontSize:13, margin:"0 0 14px" }}>Pilih atau drag-drop file JSON di sini</p>
        <label style={{ background:C.darkRed, color:"white", borderRadius:7, padding:"9px 20px", cursor:"pointer", fontSize:13, fontWeight:600 }}>
          Pilih File
          <input type="file" accept="application/json" style={{ display:"none" }} onChange={e => {
            const f = e.target.files?.[0]; if (!f) return;
            const r = new FileReader();
            r.onload = ev => {
              try {
                const data = JSON.parse(ev.target.result);
                if (Array.isArray(data)) { setTomats(data); setStatus({ ok:true, msg:`Berhasil import ${data.length} data tomat` }); }
                else setStatus({ ok:false, msg:"Format JSON harus berupa array of tomat" });
              } catch { setStatus({ ok:false, msg:"File JSON tidak valid" }); }
            };
            r.readAsText(f);
          }}/>
        </label>
      </div>
      {status && <div style={{ padding:"11px 14px", borderRadius:8, background:status.ok?"#f0fdf4":"#fef2f2", border:`1px solid ${status.ok?"#bbf7d0":"#fecaca"}`, color:status.ok?"#166534":"#dc2626", fontSize:13, marginBottom:16 }}>{status.ok?"✅":"❌"} {status.msg}</div>}
      <div style={{ background:"#f9fafb", borderRadius:8, padding:14, fontSize:12, color:C.textLt }}>
        <strong style={{ color:C.textMd }}>Format JSON yang diperlukan:</strong>
        <pre style={{ margin:"8px 0 0", fontFamily:"monospace", fontSize:11, color:"#4b5563", overflowX:"auto" }}>{`[\n  {\n    "id": 1, "kode": "T001", "nama": "Tomat 1",\n    "berat": 180, "warna": 5, "kesegaran": 9, "cacat": 2\n  }\n]`}</pre>
      </div>
    </div>
  );
}

/* ─── LAPORAN VIEW ──────────────────────────────────────── */
function LaporanView({ tomats, kriterias }) {
  const ranking = useMemo(() => saw(tomats, kriterias), [tomats, kriterias]);
  return (
    <div style={{ display:"flex", flexDirection:"column", gap:16 }}>
      <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, padding:22 }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:20 }}>
          <h2 style={{ margin:0, fontSize:15, fontWeight:700, color:C.text }}>Laporan SPK Tomat Terbaik</h2>
          <button style={{ background:"#f9fafb", color:C.textMd, border:"1px solid "+C.border, borderRadius:7, padding:"8px 14px", cursor:"pointer", fontSize:12.5, display:"flex", alignItems:"center", gap:5 }}>
            <Download size={13}/>Ekspor PDF
          </button>
        </div>
        <div style={{ display:"grid", gridTemplateColumns:"repeat(3,1fr)", gap:12, marginBottom:20 }}>
          {[{l:"Total Data Tomat",v:tomats.length},{l:"Total Kriteria",v:kriterias.length},{l:"Tomat Terbaik",v:ranking[0]?.tomat.kode||"-"}].map(it => (
            <div key={it.l} style={{ background:"#f9fafb", borderRadius:8, padding:14, textAlign:"center", border:"1px solid "+C.border }}>
              <div style={{ fontSize:10.5, color:"#9ca3af", marginBottom:3 }}>{it.l}</div>
              <div style={{ fontSize:22, fontWeight:700, color:C.darkRed }}>{it.v}</div>
            </div>
          ))}
        </div>
        <h3 style={{ fontSize:13, fontWeight:700, color:C.textMd, margin:"0 0 10px" }}>Top 10 Tomat Terbaik</h3>
        <table style={{ width:"100%", borderCollapse:"collapse" }}>
          <TableHead cols={["Rank","Kode","Nama Tomat","Nilai SAW"]}/>
          <tbody>
            {ranking.slice(0, 10).map(({ tomat, nilai }, i) => (
              <tr key={tomat.id} style={{ borderTop:"1px solid #f3f4f6" }}>
                <td style={{ ...TD, fontWeight:700, color:i<3?"#f59e0b":C.textMd }}>{i+1}</td>
                <td style={TD}>{tomat.kode}</td>
                <td style={TD}>{tomat.nama}</td>
                <td style={{ ...TD, fontWeight:700, color:C.darkRed }}>{nilai.toFixed(4)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

/* ─── PENGATURAN VIEW ───────────────────────────────────── */
function PengaturanView() {
  const items = [
    { l:"Nama Sistem",    v:"SPK Tomat Terbaik - SAW" },
    { l:"Versi",          v:"1.0.0" },
    { l:"Metode",         v:"Simple Additive Weighting (SAW)" },
    { l:"Admin Email",    v:"admin@tomatterbaik.id" },
    { l:"Total Kriteria", v:"4 kriteria aktif" },
  ];
  return (
    <div style={{ background:C.white, borderRadius:12, border:"1px solid "+C.border, padding:22 }}>
      <h2 style={{ margin:"0 0 20px", fontSize:15, fontWeight:700, color:C.text }}>Pengaturan Sistem</h2>
      {items.map(it => (
        <div key={it.l} style={{ display:"flex", alignItems:"center", padding:"13px 0", borderBottom:"1px solid #f3f4f6" }}>
          <span style={{ width:180, fontSize:13, color:"#9ca3af", fontWeight:500 }}>{it.l}</span>
          <span style={{ fontSize:13.5, color:C.text, fontWeight:500 }}>{it.v}</span>
        </div>
      ))}
    </div>
  );
}

/* ─── ROOT APP ──────────────────────────────────────────── */
export default function App() {
  const [view,     setView]     = useState("dashboard");
  const [tomats,   setTomats]   = useState(generateTomats);
  const [kriterias,setKriterias]= useState(DEFAULT_KRITERIAS);

  return (
    <div style={{ display:"flex", height:"100vh", fontFamily:"-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif", overflow:"hidden", background:C.bg }}>
      <Sidebar current={view} go={setView} />
      <div style={{ flex:1, display:"flex", flexDirection:"column", overflow:"hidden", minWidth:0 }}>
        <Header view={view} />
        <main style={{ flex:1, overflowY:"auto", background:C.bg, padding:22 }}>
          {view === "dashboard"      && <DashboardView      tomats={tomats} kriterias={kriterias} go={setView}/>}
          {view === "dataTomat"      && <DataTomatView      tomats={tomats} setTomats={setTomats}/>}
          {view === "kriteria"       && <KriteriaView       kriterias={kriterias} setKriterias={setKriterias}/>}
          {view === "penilaian"      && <PenilaianView      tomats={tomats} kriterias={kriterias} setTomats={setTomats}/>}
          {view === "importJson"     && <ImportJsonView     setTomats={setTomats}/>}
          {view === "perhitunganSaw" && <PerhitunganSAWView tomats={tomats} kriterias={kriterias}/>}
          {view === "hasilRanking"   && <HasilRankingView   tomats={tomats} kriterias={kriterias}/>}
          {view === "laporan"        && <LaporanView        tomats={tomats} kriterias={kriterias}/>}
          {view === "pengaturan"     && <PengaturanView/>}
        </main>
      </div>
    </div>
  );
}