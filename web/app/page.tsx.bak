'use client'
import { useState, useMemo } from "react";
import {
  LayoutDashboard, Apple, Sliders, ClipboardList, Upload,
  Calculator, Trophy, FileText, Settings, Menu, Eye, Pencil,
  Trash2, ChevronLeft, ChevronRight, ChevronDown, X, Plus,
  Star, Calendar, User, Info, BarChart3, Download, Database
} from "lucide-react";

/* ─── DATA ─────────────────────────────────────────────── */
function generateTomats() {
  const d = [];
  for (let i = 1; i <= 50; i++) {
    d.push({
      id: i,
      kode: `T${String(i).padStart(3, "0")}`,
      nama: `Tomat ${i}`,
      berat: 150 + ((i * 17 + 5) % 61),
      warna: 3 + (i % 3),
      kesegaran: 6 + (i % 5),
      cacat: 1 + ((i * 3 + 2) % 10),
    });
  }
  d[0]  = { ...d[0],  berat:180, warna:5, kesegaran:9,  cacat:2 };
  d[1]  = { ...d[1],  berat:175, warna:4, kesegaran:8,  cacat:4 };
  d[2]  = { ...d[2],  berat:190, warna:5, kesegaran:9,  cacat:3 };
  d[3]  = { ...d[3],  berat:160, warna:4, kesegaran:8,  cacat:5 };
  d[4]  = { ...d[4],  berat:200, warna:5, kesegaran:10, cacat:1 };
  d[49] = { ...d[49], berat:187, warna:4, kesegaran:8,  cacat:2 };
  return d;
}

const DEFAULT_KRITERIAS = [
  { id:"berat",     nama:"Berat (g)",        bobot:0.3, tipe:"benefit" },
  { id:"warna",     nama:"Warna (1-5)",      bobot:0.2, tipe:"benefit" },
  { id:"kesegaran", nama:"Kesegaran (1-10)", bobot:0.3, tipe:"benefit" },
  { id:"cacat",     nama:"Cacat (%)",        bobot:0.2, tipe:"cost"    },
];

/* ─── SAW ALGORITHM ────────────────────────────────────── */
function saw(tomats, kriterias) {
  if (!tomats.length) return [];
  const mx = {}, mn = {};
  kriterias.forEach(k => {
    const v = tomats.map(t => t[k.id]);
    mx[k.id] = Math.max(...v);
    mn[k.id] = Math.min(...v);
  });
  return tomats.map(t => {
    const nr = kriterias.map(k => {
      const v = t[k.id];
      return k.tipe === "benefit"
        ? (mx[k.id] > 0 ? v / mx[k.id] : 1)
        : (v > 0 ? mn[k.id] / v : 0);
    });
    return { tomat: t, nr, nilai: nr.reduce((s, v, i) => s + v * kriterias[i].bobot, 0) };
  }).sort((a, b) => b.nilai - a.nilai);
}

/* ─── STYLE TOKENS ─────────────────────────────────────── */
const C = {
  sidebar:"#111827", sidebarBorder:"#1f2937",
  red:"#ef4444", darkRed:"#dc2626",
  bg:"#f3f4f6", white:"#ffffff",
  text:"#111827", textMd:"#374151", textLt:"#6b7280",
  border:"#e5e7eb", borderLt:"#f3f4f6", tableHead:"#f9fafb",
};
const TD  = { padding:"10px 14px", fontSize:13, color:C.textMd };
const TH  = { padding:"10px 14px", textAlign:"left", fontSize:12, fontWeight:600, color:C.textLt, whiteSpace:"nowrap" };
const BTN = { width:27, height:27, borderRadius:6, border:"none", cursor:"pointer", display:"flex", alignItems:"center", justifyContent:"center" };

/* ─── PAGINATION ───────────────────────────────────────── */
function Pagination({ current, total, onChange }) {
  const pages = (() => {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
    const p = [1];
    if (current > 3) p.push("…");
    for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) p.push(i);
    if (current < total - 2) p.push("…");
    p.push(total);
    return p;
  })();
  const pb = active => ({
    padding:"4px 9px", borderRadius:5, border:active?"none":"1px solid "+C.border,
    background:active?C.darkRed:C.white, color:active?"white":C.textMd,
    cursor:"pointer", fontSize:12, minWidth:28, textAlign:"center", lineHeight:"18px",
  });
  return (
    <div style={{ display:"flex", gap:3, alignItems:"center" }}>
      <button onClick={() => current > 1 && onChange(current - 1)} disabled={current === 1}
        style={{ ...pb(false), opacity:current===1?0.4:1, padding:"4px 7px" }}>
        <ChevronLeft size={13} />
      </button>
      {pages.map((p, i) => (
        <button key={i} onClick={() => typeof p === "number" && onChange(p)} style={pb(p === current)}>{p}</button>
      ))}
      <button onClick={() => current < total && onChange(current + 1)} disabled={current === total}
        style={{ ...pb(false), opacity:current===total?0.4:1, padding:"4px 7px" }}>
        <ChevronRight size={13} />
      </button>
    </div>
  );
}

/* ─── MODAL ─────────────────────────────────────────────── */
function Modal({ title, onClose, children }) {
  return (
    <div style={{ position:"fixed", inset:0, zIndex:9999, background:"rgba(0,0,0,0.5)", display:"flex", alignItems:"center", justifyContent:"center" }}>
      <div style={{ background:C.white, borderRadius:12, padding:24, width:"100%", maxWidth:420, maxHeight:"85vh", overflowY:"auto", boxShadow:"0 24px 64px rgba(0,0,0,0.25)" }}>
        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", marginBottom:20 }}>
          <span style={{ fontSize:15, fontWeight:700, color:C.text }}>{title}</span>
          <button onClick={onClose} style={{ background:"none", border:"none", cursor:"pointer", color:C.textLt }}><X size={18} /></button>
        </div>
        {children}
      </div>
    </div>
  );
}

